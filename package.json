{
  "name": "gayankanishka-portfolio",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/fetch-pinned-repos.mjs && vite",
    "build": "node scripts/fetch-pinned-repos.mjs && tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
